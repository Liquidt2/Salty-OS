# ═══════════════════════════════════════════
# Salty OS — Environment Config
# Copy to .env and fill in your values
# ════════════════════════════════════──────────────────

# Database Configuration
DB_NAME=saltyos
DB_USER=salty
DB_PASSWORD=saltyos_secret

# Optional: Connection for external PG Admin
# PG_ADMIN_PASSWORD=bke_master_2026

# Salty OS Ports
SALTY_PORT=3000
API_PORT=3001

# Security
SALTY_AUTH_TOKEN=

# External Integrations (URLs only, used by dashboard)
OPENCLAW_URL=http://klaus.yourdomain.com
N8N_URL=http://n8n.yourdomain.com
POSTIZ_URL=http://postiz.yourdomain.com
FIRECRAWL_URL=http://firecrawl:3002
GOTENBERG_URL=http://gotenberg:3000

# Timezone
TZ=America/Chicago
